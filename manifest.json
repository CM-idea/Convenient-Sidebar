{
  "manifest_version": 3,
  "name": "便捷边栏",
  "version": "1.0.0",
  "description": "Edge 浏览器侧边栏插件",
  "icons": {
    "16": "icons/icon-dark16.png",
    "48": "icons/icon-dark48.png",
    "128": "icons/icon-dark128.png"
  },
  "action": {
    "default_title": "打开侧边栏",
    "default_icon": {
      "16": "icons/icon-dark16.png",
      "48": "icons/icon-dark48.png",
      "128": "icons/icon-dark128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [],
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "alarms",
    "scripting",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"]
}
